---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    badge?: string;
    order?: number;
  };
}

const { title, description, frontmatter } = Astro.props;
const pageTitle = frontmatter?.title || title;
const pageDesc = frontmatter?.description || description;
const badge = frontmatter?.badge;
---

<Layout title={pageTitle} description={pageDesc}>
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex gap-8 py-8">
      <!-- Sidebar -->
      <aside class="hidden lg:block w-64 shrink-0">
        <div class="sticky top-20">
          <Sidebar currentPath={Astro.url.pathname} />
        </div>
      </aside>

      <!-- Main content -->
      <article class="flex-1 min-w-0">
        <!-- Page header -->
        <div class="mb-8 pb-8 border-b border-zinc-700/50">
          {badge && (
            <span class="badge-lime mb-3">{badge}</span>
          )}
          <h1 class="text-3xl sm:text-4xl font-bold text-zinc-100 mt-2">{pageTitle}</h1>
          {pageDesc && (
            <p class="mt-3 text-lg text-zinc-400">{pageDesc}</p>
          )}
        </div>

        <!-- Markdown content -->
        <div class="prose prose-invert prose-zinc max-w-none
          prose-headings:text-zinc-100 prose-headings:font-bold
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:border-b prose-h2:border-zinc-700/50 prose-h2:pb-2
          prose-h3:text-xl prose-h3:text-zinc-200
          prose-p:text-zinc-300 prose-p:leading-7
          prose-a:text-lime-400 prose-a:no-underline hover:prose-a:text-lime-300 prose-a:transition-colors
          prose-strong:text-zinc-100
          prose-code:text-lime-300 prose-code:bg-zinc-800 prose-code:rounded prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
          prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-700
          prose-blockquote:border-l-lime-500 prose-blockquote:bg-zinc-800/50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
          prose-ul:text-zinc-300 prose-ol:text-zinc-300
          prose-li:marker:text-lime-500
          prose-img:rounded-xl prose-img:border prose-img:border-zinc-700 prose-img:shadow-xl
          prose-table:text-zinc-300 prose-thead:border-zinc-600 prose-tbody:border-zinc-700
          prose-th:text-zinc-200 prose-th:bg-zinc-800
          prose-hr:border-zinc-700">
          <slot />
        </div>

        <!-- Navigation between pages -->
        <div class="mt-12 pt-8 border-t border-zinc-700/50">
          <p class="text-sm text-zinc-500 text-center">
            Cảm ơn bạn đã đọc tài liệu DevHub! 
            <a href="/Docs" class="text-lime-400 hover:text-lime-300 transition-colors">← Quay về trang chủ</a>
          </p>
        </div>
      </article>

      <!-- Table of contents placeholder -->
      <div class="hidden xl:block w-56 shrink-0">
        <div class="sticky top-20">
          <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">Trên trang này</p>
          <nav class="space-y-1" id="toc" aria-label="Table of contents">
            <!-- JS-populated TOC -->
          </nav>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Auto-generate table of contents from headings
  const headings = document.querySelectorAll('article h2, article h3');
  const toc = document.getElementById('toc');
  if (toc && headings.length > 0) {
    headings.forEach((heading) => {
      const id = heading.id || heading.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') || '';
      if (!heading.id) heading.id = id;
      const isH3 = heading.tagName === 'H3';
      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = heading.textContent || '';
      if (isH3) {
        link.className = 'block text-xs text-zinc-500 hover:text-lime-400 transition-colors py-0.5 pl-3';
      } else {
        link.className = 'block text-sm text-zinc-400 hover:text-lime-400 transition-colors py-0.5';
      }
      toc.appendChild(link);
    });
  }
</script>
