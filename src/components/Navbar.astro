---
const navLinks = [
  { href: '/Docs/docs/getting-started', label: 'Tài liệu' },
  { href: '/Docs/docs/api-reference', label: 'API' },
  { href: '/Docs/docs/examples', label: 'Ví dụ' },
  { href: 'https://github.com/Devhub-Solutions', label: 'GitHub', external: true },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-zinc-900/95 backdrop-blur-sm border-b border-zinc-800">
  <nav class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/Docs" class="flex items-center gap-2.5 group">
      <div class="w-8 h-8 bg-lime-500 rounded-lg flex items-center justify-center shadow-lg shadow-lime-500/20 group-hover:bg-lime-400 transition-colors">
        <svg class="w-5 h-5 text-zinc-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <span class="font-bold text-lg text-zinc-100 group-hover:text-white transition-colors">
        DevHub <span class="text-lime-400">Docs</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class:list={[
            'px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150',
            currentPath.startsWith(link.href) && !link.external
              ? 'text-lime-400 bg-lime-500/10'
              : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800',
          ]}
        >
          {link.label}
          {link.external && (
            <svg class="inline w-3.5 h-3.5 ml-1 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          )}
        </a>
      ))}
    </div>

    <!-- Search + CTA -->
    <div class="flex items-center gap-2">
      <!-- Search button -->
      <button
        aria-label="Search docs"
        class="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-lg text-sm text-zinc-400 hover:text-zinc-200 transition-all min-w-[180px] group"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="flex-1">Tìm kiếm...</span>
        <kbd class="hidden sm:inline-block text-xs bg-zinc-700 border border-zinc-600 rounded px-1.5 py-0.5 font-mono opacity-60">⌘K</kbd>
      </button>

      <!-- GitHub star -->
      <a
        href="https://github.com/Devhub-Solutions/Docs"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 hover:border-lime-500/50 rounded-lg text-sm text-zinc-300 hover:text-lime-400 transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" aria-label="Toggle menu" class="md:hidden p-2 rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800 bg-zinc-900 px-4 py-3 space-y-1">
    {navLinks.map((link) => (
      <a
        href={link.href}
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noopener noreferrer' : undefined}
        class:list={[
          'block px-3 py-2 rounded-lg text-sm font-medium transition-all',
          currentPath.startsWith(link.href) && !link.external
            ? 'text-lime-400 bg-lime-500/10'
            : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
