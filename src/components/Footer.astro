---
const year = new Date().getFullYear();
---

<footer class="bg-zinc-900 border-t border-zinc-800 mt-auto">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/Docs" class="flex items-center gap-2 mb-4 group w-fit">
          <div class="w-7 h-7 bg-lime-500 rounded-md flex items-center justify-center">
            <svg class="w-4 h-4 text-zinc-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="font-bold text-zinc-100">DevHub <span class="text-lime-400">Docs</span></span>
        </a>
        <p class="text-zinc-400 text-sm leading-relaxed max-w-xs">
          Tài liệu kỹ thuật toàn diện cho các nhà phát triển. Được xây dựng với Astro và Tailwind CSS.
        </p>
        <div class="flex gap-3 mt-4">
          <a href="https://github.com/Devhub-Solutions" target="_blank" rel="noopener noreferrer"
            class="text-zinc-500 hover:text-lime-400 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-zinc-300 mb-3">Tài liệu</h3>
        <ul class="space-y-2 text-sm text-zinc-500">
          <li><a href="/Docs/docs/getting-started" class="hover:text-lime-400 transition-colors">Bắt đầu</a></li>
          <li><a href="/Docs/docs/installation" class="hover:text-lime-400 transition-colors">Cài đặt</a></li>
          <li><a href="/Docs/docs/configuration" class="hover:text-lime-400 transition-colors">Cấu hình</a></li>
          <li><a href="/Docs/docs/deployment" class="hover:text-lime-400 transition-colors">Triển khai</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-zinc-300 mb-3">Khác</h3>
        <ul class="space-y-2 text-sm text-zinc-500">
          <li><a href="/Docs/docs/api-reference" class="hover:text-lime-400 transition-colors">API Reference</a></li>
          <li><a href="/Docs/docs/examples" class="hover:text-lime-400 transition-colors">Ví dụ</a></li>
          <li><a href="/Docs/docs/changelog" class="hover:text-lime-400 transition-colors">Changelog</a></li>
          <li>
            <a href="https://github.com/Devhub-Solutions/Docs" target="_blank" rel="noopener noreferrer" class="hover:text-lime-400 transition-colors">
              GitHub ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-zinc-800 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-zinc-500 text-sm">
        &copy; {year} DevHub Solutions. Bản quyền thuộc về tác giả.
      </p>
      <div class="flex items-center gap-2 text-xs text-zinc-600">
        <span>Được xây dựng với</span>
        <span class="text-lime-500 font-semibold">Astro</span>
        <span>&amp;</span>
        <span class="text-lime-500 font-semibold">Tailwind CSS</span>
      </div>
    </div>
  </div>
</footer>
